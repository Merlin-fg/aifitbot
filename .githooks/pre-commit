#!/bin/bash
# ============================================================
# AIFitBot Git Pre-commit Hook — 门禁系统
# 检查单元测试和质量审查通行证，缺失或未通过则拒绝提交
# 通行证有效期: 30 分钟
# ============================================================

set -e

GATE_DIR=".gate"
TESTER_PASS="$GATE_DIR/tester.pass"
QUALITY_PASS="$GATE_DIR/quality.pass"
TTL_MINUTES=30

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

check_pass() {
    local pass_file="$1"
    local pass_name="$2"

    if [ ! -f "$pass_file" ]; then
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}❌ 缺少通行证: ${pass_name}${NC}"
        echo -e "${YELLOW}   请先通过质量检查再提交${NC}"
        echo -e "${YELLOW}   → 在对话中输入 /git-save 自动完成检查${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        exit 1
    fi

    # 用 Python 解析 JSON 通行证（Windows/macOS 通用）
    local passed=$(python -c "import json; data=json.load(open('$pass_file')); print(data.get('passed', False))" 2>/dev/null)
    local timestamp=$(python -c "import json; data=json.load(open('$pass_file')); print(data.get('timestamp', ''))" 2>/dev/null)
    local summary=$(python -c "import json; data=json.load(open('$pass_file')); print(data.get('summary', ''))" 2>/dev/null)

    if [ "$passed" != "True" ]; then
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}❌ 通行证未通过: ${pass_name}${NC}"
        echo -e "${YELLOW}   详情: ${summary}${NC}"
        echo -e "${YELLOW}   请修复问题后重新检查${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        exit 1
    fi

    # 检查 TTL 是否过期
    local pass_epoch=$(python -c "from datetime import datetime; print(int(datetime.fromisoformat('$timestamp').timestamp()))" 2>/dev/null)
    local now_epoch=$(python -c "import time; print(int(time.time()))" 2>/dev/null)
    local age=$(( now_epoch - pass_epoch ))
    local ttl_seconds=$(( TTL_MINUTES * 60 ))

    if [ "$age" -gt "$ttl_seconds" ]; then
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}❌ 通行证已过期: ${pass_name}${NC}"
        echo -e "${YELLOW}   签发时间: ${timestamp}${NC}"
        echo -e "${YELLOW}   已过 ${age} 秒 (有效期 ${TTL_MINUTES} 分钟)${NC}"
        echo -e "${YELLOW}   请重新运行质量检查${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        exit 1
    fi

    local remaining=$(( (ttl_seconds - age) / 60 ))
    echo -e "${GREEN}✅ 通行证有效: ${pass_name} (剩余 ${remaining} 分钟) — ${summary}${NC}"
}

echo ""
echo -e "${GREEN}══════════════════════════════════════${NC}"
echo -e "${GREEN}  AIFitBot 提交门禁检查${NC}"
echo -e "${GREEN}══════════════════════════════════════${NC}"

check_pass "$TESTER_PASS" "单元测试"
check_pass "$QUALITY_PASS" "质量审查"

echo ""
echo -e "${GREEN}🎉 所有检查通过，允许提交${NC}"
echo ""
exit 0
